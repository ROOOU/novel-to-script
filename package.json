    "docx": "^9.6.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "openai": "^6.32.0",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.8",
    "protobufjs": "^7.5.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
