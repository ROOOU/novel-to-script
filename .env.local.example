# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret

# LLM provider
# Any OpenAI-compatible gateway works here, including self-hosted new-api.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_NAME=gemini-2.5-flash

# Example: Gemini via QuantumNous/new-api
# LLM_API_KEY=sk-newapi-xxxx
# LLM_BASE_URL=https://your-new-api-domain.com/v1
# LLM_MODEL_NAME=gemini-2.5-flash
# Optional provider failover chain (JSON array)
# LLM_FALLBACKS=[{"apiKey":"sk-backup","baseUrl":"https://backup-gateway.example.com/v1","modelName":"gemini-2.5-flash","label":"backup"}]

# Database runtime
DATABASE_URL=
DATABASE_POOL_SIZE=1
DATABASE_IDLE_TIMEOUT=20
DATABASE_CONNECT_TIMEOUT=10

# Optional async job queue
REDIS_URL=

# Optional local artifact store override
NOVELSCRIPT_STORE_PATH=.novelscript/store

# PayPal billing
# `localhost` is fine for local development, but real PayPal sandbox callbacks need
# a public HTTPS URL in NEXT_PUBLIC_APP_URL.
# credit-pack minimum: PAYPAL_CLIENT_ID, PAYPAL_CLIENT_SECRET, PAYPAL_MODE, PAYPAL_WEBHOOK_ID
# subscription also needs: PAYPAL_PLAN_ID_CREATOR, PAYPAL_PLAN_ID_PRO
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_HTTP_TIMEOUT_MS=15000
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_ID_CREATOR=
PAYPAL_PLAN_ID_PRO=

# Legacy / compatibility aliases
# NOVELSCRIPT_AUTH_SECRET=
# PAYPAL_PLAN_ID=
